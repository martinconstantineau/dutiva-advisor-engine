# ─── LLM provider — Qwen (required) ────────────────────────────────────────
QWEN_API_KEY=
# Optional: defaults to https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=
QWEN_MODEL=
QWEN_TIMEOUT_MS=30000
QWEN_MAX_RETRIES=2

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── Real-time web search — Startpage (optional) ────────────────────────────
# Set WEB_SEARCH_ENABLED=true AND provide STARTPAGE_BASE_URL + STARTPAGE_API_KEY
# to enable live Startpage web search. Defaults to false (safe default).
# Both this global flag AND options.enableWebSearch=true per-request are required.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=startpage

# Startpage API adapter endpoint (required for live search).
# Because Startpage does not publish an official public API, configure a
# contracted/approved adapter endpoint here. Do NOT commit real values.
STARTPAGE_BASE_URL=
STARTPAGE_API_KEY=

# Optional Startpage tuning
STARTPAGE_TIMEOUT_MS=10000
STARTPAGE_MAX_RESULTS=5
STARTPAGE_REGION=ca
STARTPAGE_LANGUAGE=en

# Web search cache TTL in seconds (default 900 = 15 min)
WEB_SEARCH_CACHE_TTL_SECONDS=900

# Source-page fetch timeout (for future source-content fetching, default 10000ms)
WEB_FETCH_TIMEOUT_MS=10000
