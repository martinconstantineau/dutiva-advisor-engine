{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutiva.ca/schemas/advisor-training/source-registry.schema.json",
  "title": "Dutiva source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "last_reviewed_at", "description", "source_types", "sources"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Law",
          "Regulation",
          "Government guide",
          "Internal Dutiva template",
          "Internal Dutiva policy",
          "HR best-practice guidance",
          "PR/internal communications guidance"
        ]
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "source_name",
          "source_type",
          "jurisdiction",
          "url",
          "language",
          "authority_level",
          "last_checked_at",
          "last_updated_at",
          "status",
          "notes"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source_name": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": [
              "Law",
              "Regulation",
              "Government guide",
              "Internal Dutiva template",
              "Internal Dutiva policy",
              "HR best-practice guidance",
              "PR/internal communications guidance"
            ]
          },
          "jurisdiction": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string",
            "enum": ["English", "French", "Bilingual", "Multilingual"]
          },
          "authority_level": {
            "type": "string",
            "enum": [
              "Primary law",
              "Primary regulation",
              "Official government guidance",
              "Internal Dutiva product source",
              "Internal Dutiva policy",
              "Internal Dutiva guidance",
              "Internal Dutiva communications guidance"
            ]
          },
          "last_checked_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "last_updated_at": {
            "type": ["string", "null"],
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "paused", "deprecated"]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
