{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutiva.local/schemas/guidance-card.schema.json",
  "title": "Dutiva guidance card (curated-review layer — FUTURE)",
  "description": "IMPORTANT: This schema is for the FUTURE human-curated guidance card review layer, NOT for the generated guidance cards produced by the source-law ingestion pipeline. For generated guidance cards (the actual runtime corpus), see generated-guidance-card.schema.json. This schema defines the shape expected by a future editorial review/approval workflow where Dutiva staff curate, approve, and add employer_size and dutiva_recommendation fields before publishing. Do not use this schema to validate advisor-training pipeline output.",
  "type": "object",
  "required": [
    "guidance_id",
    "topic",
    "jurisdiction",
    "employer_size",
    "risk_level",
    "plain_language_summary",
    "dutiva_recommendation",
    "source_references",
    "last_reviewed_at",
    "review_status"
  ],
  "properties": {
    "guidance_id": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "jurisdiction": { "type": "string", "minLength": 1 },
    "employer_size": { "type": "string", "minLength": 1 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "plain_language_summary": { "type": "string", "minLength": 1 },
    "dutiva_recommendation": { "type": "string", "minLength": 1 },
    "source_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_url"],
        "properties": {
          "source_url": { "type": "string", "minLength": 1 },
          "section_id": { "type": "string" },
          "section_number": { "type": "string" },
          "section_title": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "last_reviewed_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "review_status": { "type": "string", "enum": ["draft", "needs_review", "approved", "deprecated"] }
  },
  "additionalProperties": true
}
