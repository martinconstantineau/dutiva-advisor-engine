{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutiva.local/schemas/parsed-document.schema.json",
  "title": "Dutiva parsed document section",
  "type": "object",
  "required": [
    "document_id",
    "title",
    "jurisdiction",
    "source_type",
    "section_id",
    "section_title",
    "section_number",
    "body_text",
    "language",
    "source_url"
  ],
  "properties": {
    "document_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "jurisdiction": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "section_id": { "type": "string", "minLength": 1 },
    "section_title": { "type": "string", "minLength": 1 },
    "section_number": { "type": "string", "minLength": 1 },
    "body_text": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
