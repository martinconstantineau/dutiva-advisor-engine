{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-pipelines",
    "module": "commonjs",
    "target": "ES2020",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "advisor-training/pipelines/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-pipelines"
  ]
}
